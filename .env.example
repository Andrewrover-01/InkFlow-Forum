# ============================================================
# 墨香论坛 (InkFlow Forum) — 环境变量配置模板
# 使用方法：将本文件复制为 .env，然后填入真实值
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# PostgreSQL — Docker Compose 服务名 "postgres"
# Docker 部署时 HOST 填写 docker-compose 中数据库服务名 (postgres)
# 本地开发时填写 localhost
# ------------------------------------------------------------
POSTGRES_DB="inkflow"
POSTGRES_USER="inkflow_user"
POSTGRES_PASSWORD="change-me-strong-password"

# 完整连接字符串（docker-compose.yml 会自动从上面三个变量拼装）
# 本地开发时手动填写：
DATABASE_URL="postgresql://inkflow_user:change-me-strong-password@localhost:5432/inkflow"

# ------------------------------------------------------------
# NextAuth.js 配置 (JWT_SECRET)
# NEXTAUTH_SECRET: 用于签名 JWT 的密钥，任意随机字符串
#   生产环境请用强随机值: openssl rand -base64 32
# NEXTAUTH_URL: 应用的完整访问地址（末尾无斜线）
#   Docker 部署: http://your-server-ip  或  https://your-domain.com
#   本地开发: http://localhost:3000
# ------------------------------------------------------------
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# CAPTCHA 人机验证
# CAPTCHA_BYPASS_TOKEN: 服务端测试绕过令牌（仅 CI/测试环境使用）
# NEXT_PUBLIC_CAPTCHA_BYPASS_TOKEN: 客户端测试绕过令牌（仅 CI/测试环境使用）
# 生产环境请删除或留空这两个变量
# ------------------------------------------------------------
CAPTCHA_BYPASS_TOKEN=""
NEXT_PUBLIC_CAPTCHA_BYPASS_TOKEN=""

# ------------------------------------------------------------
# Cloudflare R2 — 头像图片上传
# 用于 POST /api/upload 端点
# R2_ACCOUNT_ID:       Cloudflare 帐号 ID（在 R2 概览页右侧可找到）
# R2_ACCESS_KEY_ID:    R2 API Token 的 Access Key ID
# R2_SECRET_ACCESS_KEY: R2 API Token 的 Secret Access Key
# R2_BUCKET:           R2 存储桶名称
# R2_PUBLIC_URL:       存储桶绑定的公开访问域名（末尾无斜线）
#   示例: https://pub-xxxxxxxxxxxx.r2.dev
#         或自定义域名 https://cdn.your-domain.com
# ------------------------------------------------------------
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="inkflow-avatars"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"
