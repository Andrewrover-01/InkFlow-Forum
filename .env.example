# ============================================================
# 墨香论坛 (InkFlow Forum) — 环境变量配置模板
# 使用方法：将本文件复制为 .env，然后填入真实值
#   cp .env.example .env
# ============================================================

# ============================================================
# ── Docker Compose 专用变量 ──────────────────────────────────
# ============================================================

# ── PostgreSQL (Next.js / Prisma) ────────────────────────────
POSTGRES_DB=inkflow
POSTGRES_USER=inkflow
POSTGRES_PASSWORD=change-me-postgres-password

# ── MySQL (Spring Boot 后端) ──────────────────────────────────
MYSQL_DATABASE=inkflow_forum
MYSQL_USER=inkflow
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password

# ── Redis ─────────────────────────────────────────────────────
# 留空则 Redis 不设密码（开发环境可留空）
REDIS_PASSWORD=

# ── Spring Boot JWT ───────────────────────────────────────────
# 生产环境必须替换为强随机值: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64

# ============================================================
# ── Next.js (前端) 变量 ──────────────────────────────────────
# ============================================================

# ------------------------------------------------------------
# 数据库连接 (本地开发直连)
# Docker Compose 部署时由 docker-compose.yml 自动拼接，无需在此修改
# 本地开发示例: postgresql://postgres:password@localhost:5432/inkflow
# ------------------------------------------------------------
DATABASE_URL="postgresql://inkflow:change-me-postgres-password@localhost:5432/inkflow"

# ------------------------------------------------------------
# NextAuth.js 配置
# NEXTAUTH_SECRET: 用于签名 JWT 的密钥
#   生产环境: openssl rand -base64 32
# NEXTAUTH_URL: 应用的完整访问地址
#   本地开发: http://localhost:3000
#   Docker / 生产: http://localhost  (或 https://your-domain.com)
# ------------------------------------------------------------
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost"

# ------------------------------------------------------------
# Cloudflare R2 — 头像图片上传（可选）
# ------------------------------------------------------------
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="inkflow-avatars"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ------------------------------------------------------------
# CAPTCHA 验证绕过（仅用于开发测试，生产环境勿设置）
# ------------------------------------------------------------
# CAPTCHA_BYPASS_TOKEN="dev-bypass-token"
# NEXT_PUBLIC_CAPTCHA_BYPASS_TOKEN="dev-bypass-token"
