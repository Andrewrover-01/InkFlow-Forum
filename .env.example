# ============================================================
# 墨香论坛 (InkFlow Forum) — 环境变量配置模板
# 使用方法：将本文件复制为 .env，然后填入真实值
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 数据库连接
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 本地示例: postgresql://postgres:password@localhost:5432/inkflow
# ------------------------------------------------------------
DATABASE_URL="postgresql://用户名:密码@localhost:5432/inkflow"

# ------------------------------------------------------------
# NextAuth.js 配置
# NEXTAUTH_SECRET: 用于签名 JWT 的密钥，任意随机字符串
#   生产环境请用强随机值: openssl rand -base64 32
# NEXTAUTH_URL: 应用的完整访问地址（末尾无斜线）
#   本地开发: http://localhost:3000
#   生产环境: https://your-domain.com
# ------------------------------------------------------------
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
